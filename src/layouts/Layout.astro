---
import SpeedInsights from '@vercel/speed-insights/astro';
import Analytics from '@vercel/analytics/astro';
import Footer from '../components/Footer.astro';
import { Font } from 'astro:assets';

interface Props {
  title?: string;
  description?: string;
  /** Tighter vertical padding so dense pages (e.g. home) can fit in ~100dvh */
  compactMain?: boolean;
  frontmatter?: {
    minutesRead: string;
    title: string;
    url: string;
  };
}
const { frontmatter, title, description, compactMain = false } = Astro.props;
import '../../styles/global.css';
import { Head } from 'astro-capo';
---

<html lang="en" class="scroll-smooth dark">
  <Head>
    <script is:inline>
      try {
        if (localStorage.getItem('theme') === 'light') {
          document.documentElement.classList.remove('dark');
        } else {
          document.documentElement.classList.add('dark');
        }
      } catch {
        document.documentElement.classList.add('dark');
      }
    </script>
    <Font cssVariable="--font-figtree" preload />
    <Font cssVariable="--font-bricolage" preload />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <!-- MPA view transitions: served from /public so @view-transition isn’t dropped by CSS tooling -->
    <link rel="stylesheet" href="/view-transitions.css" />
    <meta charset="utf-8" />
    <title>{title ?? frontmatter?.title}</title>
    <meta content={title ?? frontmatter?.title} property="og:title" />
    <meta content={title ?? frontmatter?.title} property="twitter:title" />
    <meta name="twitter:card" content="summary_large_image" />
    {
      description ? (
        <>
          <meta content={description} name="description" />
          <meta content={description} property="twitter:description" />
          <meta content={description} property="og:description" />
          <meta name="author" content="Thomas Ledoux" />
        </>
      ) : (
        <>
          <meta
            content="Thomas is a frontend developer from Ghent, Belgium. Specialised in React."
            name="description"
          />
          <meta
            content="Thomas is a frontend developer from Ghent, Belgium. Specialised in React."
            property="twitter:description"
          />
          <meta
            content="Thomas is a frontend developer from Ghent, Belgium. Specialised in React."
            property="og:description"
          />
        </>
      )
    }
    <meta
      content={frontmatter?.title
        ? `https://thomasledoux.be${frontmatter.url}/og-image.png`
        : 'https://res.cloudinary.com/dzrea5zhv/image/upload/v1583171588/me_qvrwky.jpg'}
      property="og:image"
    />
    <meta
      content={frontmatter?.title
        ? `https://thomasledoux.be${frontmatter.url}/og-image.png`
        : 'https://res.cloudinary.com/dzrea5zhv/image/upload/v1583171588/me_qvrwky.jpg'}
      property="twitter:image"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SpeedInsights />
    <Analytics />
  </Head>
  <body
    class="flex flex-col font-body min-h-[100dvh] bg-bg text-fg transition-colors duration-200"
  >
    <main
      class:list={[
        'grow flex flex-col container mx-auto h-full',
        compactMain
          ? 'pt-5 pb-3 sm:pt-7 sm:pb-5'
          : 'pt-8 pb-24 sm:pb-8',
      ]}
    >
      <slot />
    </main>
    <Footer />
    <script>
      import { actions } from 'astro:actions';
      void actions.pageView({ url: window.location.pathname });
    </script>
    <script is:inline>
      try {
        if (typeof console !== 'undefined' && console.info) {
          console.info(
            '%c thomasledoux.be %c Ghent · frontend — if you are peeking here, you are probably the right kind of visitor.',
            'background:#2c6e49;color:#c6ebbe;padding:2px 8px;border-radius:4px;font-weight:600;',
            'color:#6b9080;font-style:italic;',
          );
        }
      } catch {
        /* ignore */
      }
    </script>
  </body>
</html>
