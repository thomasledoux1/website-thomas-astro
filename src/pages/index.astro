---
import { Image } from 'astro:assets';
import profilePicture from './../assets/me.png';
import '../../styles/global.css';
import Layout from '../layouts/Layout.astro';
import HomeProfilePhoto from '../components/ui/HomeProfilePhoto.astro';
import { homeHeroEnter, homeImageEnter, profileImage } from '../lib/ui-classes';
import HomeTerminal from '../components/HomeTerminal';
---

<Layout
  compactMain
  description="Thomas Ledoux' personal website. Writes about Javascript/React/Next.js/Remix/Astro. Always looking to learn about the newest frameworks and features."
  title="Thomas Ledoux - Home"
>
  <div
    class="mx-auto flex w-full max-w-4xl flex-1 flex-col lg:justify-center gap-3 min-h-[calc(100dvh-7rem)] sm:gap-4 sm:py-6 lg:min-h-[calc(100dvh-6.5rem)]"
  >
    <section class="relative lg:pt-0 items-center flex flex-wrap shrink-0">
      <div
        class="gap-6 lg:gap-8 w-full flex flex-col lg:flex-row items-center justify-between"
      >
        <h1
          class="font-title flex grow flex-col items-center gap-2 font-bold tracking-tight text-center md:leading-[1.1] lg:items-start lg:gap-3 lg:text-left"
        >
          <span
            class:list={[
              homeHeroEnter,
              'inline-block text-fg max-lg:will-change-[opacity] lg:will-change-[transform,opacity] text-4xl sm:text-6xl xl:text-7xl 2xl:text-[5.25rem] [animation-delay:0.1s]',
            ]}>Thomas Ledoux.</span
          >
        </h1>
        <div
          class:list={[
            homeImageEnter,
            'w-[10rem] sm:w-[11rem] lg:w-[12.5rem] [animation-delay:0.5s]',
          ]}
        >
          <HomeProfilePhoto>
            <Image
              src={profilePicture}
              class:list={[
                profileImage,
                'relative rounded-full mx-auto md:ml-auto lg:mr-0 aspect-square max-w-[10rem] sm:max-w-[11rem] lg:max-w-[12.5rem] max-h-[10rem] sm:max-h-[11rem] lg:max-h-[12.5rem] w-full shadow-2xl',
              ]}
              alt="Thomas Ledoux profile"
              loading="eager"
              decoding="sync"
              widths={[256, 352]}
              sizes="(max-width: 1023px) 160px, 200px"
            />
          </HomeProfilePhoto>
        </div>
      </div>
    </section>

    <section aria-label="Interactive terminal" class="flex shrink-0 flex-col">
      <div
        class:list={[homeHeroEnter, 'flex flex-col [animation-delay:0.55s]']}
      >
        <p
          class="text-fg-muted text-center lg:text-left text-sm sm:text-base mb-3 max-w-2xl"
        >
          A tiny command line to learn a bit more — try{' '}
          <kbd
            class="rounded border border-border bg-surface-tag px-1.5 py-0.5 font-mono text-sm text-fg"
            >/help</kbd
          >.
        </p>
        <HomeTerminal client:load />
      </div>
    </section>
  </div>
</Layout>
