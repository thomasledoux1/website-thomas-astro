---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import { interactiveCard } from '../lib/ui-classes';

interface Props {
  post: CollectionEntry<'blog'>;
  index: number;
}
const { post } = Astro.props;
const { remarkPluginFrontmatter } = await render(Astro.props.post);
const { minutesRead } = remarkPluginFrontmatter;
---

<a
  href={`/blog/${post.id}`}
  class:list={[interactiveCard, 'group h-full bg-surface rounded-2xl border border-border/80 p-8 lg:p-10 flex flex-col hover:border-border-strong hover:shadow-2xl hover:shadow-card focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary/40 active:brightness-[0.99]']}
>
  <article class="flex flex-col grow">
    <time
      class="text-sm text-fg-meta mb-4"
      datetime={new Date(post.data.date).toISOString()}
    >
      {
        new Date(post.data.date).toLocaleDateString('en-BE', {
          day: 'numeric',
          month: 'short',
          year: 'numeric',
        })
      }
    </time>
    <div class="flex flex-col gap-y-4 grow">
      <h2
        class="text-xl font-bold leading-snug tracking-tight text-fg transition-colors duration-200 ease-out group-hover:text-link lg:text-2xl"
      >
        {post.data.title}
      </h2>
      {minutesRead ? <p class="text-fg-meta text-sm">{minutesRead}</p> : null}
      <ul class="flex flex-wrap gap-2 mt-auto">
        {
          post.data.tags?.map((tag: string) => (
            <li class="bg-surface-tag text-fg-muted text-xs lg:text-sm py-2 px-4 rounded-full font-medium tracking-wider uppercase">
              {tag}
            </li>
          ))
        }
      </ul>
    </div>
    <div
      class="mt-6 hidden md:flex items-center text-link opacity-0 group-hover:opacity-100 transition-opacity duration-200 ease-out"
    >
      <span class="text-sm font-medium mr-2">Read post</span>
      <svg
        class="w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-200 ease-out"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9 5l7 7-7 7"></path>
      </svg>
    </div>
  </article>
</a>
