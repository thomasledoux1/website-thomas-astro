---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import { interactiveCard } from '../lib/ui-classes';

interface Props {
  post: CollectionEntry<'blog'>;
  index: number;
  /** Spans full row on `lg` (use for the most recent post in a 2-column grid). */
  featured?: boolean;
}
const { post, featured = false } = Astro.props;
const { remarkPluginFrontmatter } = await render(Astro.props.post);
const { minutesRead } = remarkPluginFrontmatter;
---

<a
  href={`/blog/${post.id}`}
  class:list={[
    interactiveCard,
    'group flex h-full flex-col rounded-2xl border border-border/80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-secondary/40 active:brightness-[0.99]',
    featured
      ? 'lg:col-span-2 bg-gradient-to-br from-primary/[0.07] via-surface to-surface p-6 shadow-lg shadow-card/35 ring-1 ring-secondary/20 dark:from-primary/[0.11] sm:p-8 lg:p-10 xl:p-12'
      : 'bg-surface p-8 lg:p-10',
    'hover:border-border-strong hover:shadow-2xl hover:shadow-card',
    featured && 'hover:ring-secondary/30',
  ]}
>
  <article class="flex grow flex-col">
    <time
      class:list={['text-sm text-fg-meta', featured ? 'mb-3' : 'mb-4']}
      datetime={new Date(post.data.date).toISOString()}
    >
      {
        new Date(post.data.date).toLocaleDateString('en-BE', {
          day: 'numeric',
          month: 'short',
          year: 'numeric',
        })
      }
    </time>
    <div class="flex grow flex-col gap-y-4">
      <h2
        class:list={[
          'font-bold leading-snug tracking-tight text-fg transition-colors duration-200 ease-out group-hover:text-link',
          featured
            ? 'text-xl sm:text-2xl lg:text-3xl xl:text-4xl xl:leading-[1.15]'
            : 'text-xl lg:text-2xl',
        ]}
      >
        {post.data.title}
      </h2>
      {minutesRead ? <p class="text-sm text-fg-meta">{minutesRead}</p> : null}
      <ul class="mt-auto flex flex-wrap gap-2">
        {
          post.data.tags?.map((tag: string) => (
            <li class="rounded-full bg-surface-tag px-4 py-2 text-xs font-medium uppercase tracking-wider text-fg-muted lg:text-sm">
              {tag}
            </li>
          ))
        }
      </ul>
    </div>
    <div
      class="mt-6 hidden items-center text-link opacity-0 transition-opacity duration-200 ease-out md:flex group-hover:opacity-100"
    >
      <span class="mr-2 text-sm font-medium">Read post</span>
      <svg
        class="h-4 w-4 transform transition-transform duration-200 ease-out group-hover:translate-x-1"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9 5l7 7-7 7"
        />
      </svg>
    </div>
  </article>
</a>
