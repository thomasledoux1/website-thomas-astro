---
import FooterLink from "./FooterLink.astro";
import ThemeToggle from "./ThemeToggle.astro";
import HomeLogo from "../assets/HomeLogo.svg";
import PersonalLogo from "../assets/PersonalLogo.svg";
import PortfolioLogo from "../assets/PortfolioLogo.svg";
// import SearchLogo from "../assets/SearchLogo.svg";
import BlogLogo from "../assets/BlogLogo.svg";
import ContactLogo from "../assets/ContactLogo.svg";
import LinkedInLogo from "../assets/LinkedInLogo.svg";
---

<footer
  class="[view-transition-name:site-footer] fixed z-30
  left-1/2 bottom-2 -translate-x-1/2 translate-y-0
  sm:left-4 sm:top-1/2 sm:bottom-auto sm:-translate-x-0 sm:-translate-y-1/2"
>
  <nav
    class="bg-footer-dock text-footer-dock-fg rounded-2xl flex items-center max-w-[calc(100vw-1rem)] px-3 sm:px-3 lg:px-4 py-4 lg:py-6"
  >
    <ul class="flex sm:flex-col gap-3 sm:gap-2 items-center justify-center min-w-0">
      <FooterLink label="Home" href="/"><HomeLogo /></FooterLink>
      <FooterLink label="Personal" href="/personal"><PersonalLogo /></FooterLink
      >
      <FooterLink label="Portfolio" href="/portfolio"
        ><PortfolioLogo /></FooterLink
      >
      <FooterLink label="Blog" href="/blog"><BlogLogo /></FooterLink>
      <!-- <FooterLink label="Search" href="/search"><SearchLogo /></FooterLink> -->
      <li
        aria-hidden="true"
        class="shrink-0 w-px h-7 self-center bg-footer-dock-border my-2 sm:my-1 sm:h-[2px] sm:w-[1.82rem] sm:min-h-0 sm:self-center"
      />
      <FooterLink label="Contact" href="mailto:hello@thomasledoux.be"
        ><ContactLogo /></FooterLink
      >
      <FooterLink
        label="LinkedIn"
        href="https://www.linkedin.com/in/thomasledoux91"
        ><LinkedInLogo /></FooterLink
      >
      <li
        class="group flex shrink-0 items-center justify-center py-[6px] xs:py-2 sm:py-0 z-40 relative"
      >
        <ThemeToggle dock />
      </li>
    </ul>
  </nav>
</footer>
