---
interface Props {
  index: number;
  isActive?: boolean;
}
const { index, isActive = false } = Astro.props;
const ease = 'ease-[cubic-bezier(0.23,1,0.32,1)]';
---

<button
  type="button"
  data-carousel-dot
  class:list={[
    'group h-2 rounded-full cursor-pointer min-w-[2rem] flex-1 relative overflow-hidden',
    'bg-gray-200/50 transition-colors duration-200 motion-reduce:transition-none',
    ease,
    '[&.active]:bg-secondary',
    isActive && 'active',
  ]}
  aria-label={`Scroll to slide ${index + 1}`}
>
  <span
    class:list={[
      'pointer-events-none absolute inset-0 origin-left bg-secondary',
      'scale-x-0 transition-transform duration-200 motion-reduce:duration-0',
      ease,
      'group-hover:scale-x-[0.3] group-[.active]:scale-x-100 group-[.active]:group-hover:scale-x-100',
    ]}
  />
</button>
